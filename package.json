{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Full-stack Discord bot with React dashboard",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "pnpm --filter discord-bot-backend dev",
    "dev:frontend": "pnpm --filter discord-bot-frontend dev",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "pnpm --filter discord-bot-backend build",
    "build:frontend": "pnpm --filter discord-bot-frontend build",
    "start:backend": "pnpm --filter discord-bot-backend start",
    "start:frontend": "serve -s frontend/dist -l 3000",
    "start": "concurrently \"pnpm run start:frontend\" \"pnpm run start:backend\"",
    "install:all": "pnpm install",
    "db:setup": "pnpm --filter discord-bot-backend db:generate && pnpm --filter discord-bot-backend db:push"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "serve": "^14.2.6"
  }
}
